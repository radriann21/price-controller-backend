// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output = "../src/prisma/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model globalProfitMargin {
  id Int @id @default(autoincrement())
  profitMargin Decimal @db.Decimal(5,2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Categories {
  id  Int @id @default(autoincrement())
  name String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive Boolean @default(true)
  products Products[]
}

model ExchangeRates {
  id Int @id @default(autoincrement())
  source String
  rate Decimal @db.Decimal(10,2)
  createdAt DateTime @default(now())
}

model Products {
  id String @default(uuid()) @id 
  name String
  costUsd Decimal @db.Decimal(10,2)
  profitMargin Decimal @db.Decimal(5,2)
  priceVes Decimal @db.Decimal(10,2)
  buyPriceVes Decimal @db.Decimal(10,2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive Boolean @default(true)
  historyPrices historyPrices[]
  categoryId Int
  category Categories @relation(fields: [categoryId], references: [id])
}

model historyPrices {
  id String @default(uuid()) @id 
  oldPriceVes Decimal @db.Decimal(10,2)
  newPriceVes Decimal @db.Decimal(10,2)
  products  Products @relation(fields: [product_id], references: [id])
  product_id String
}

model Users {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username  String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  isActive  Boolean  @default(true)
}

